{
  "name": "pixbook",
  "version": "0.1.0",
  "private": true,
  "description": "修图约 · Pixbook — 修图服务预约排期系统",
  "scripts": {
    "dev:server": "pnpm --filter @pixbook/server dev",
    "dev:admin": "pnpm --filter @pixbook/admin dev",
    "dev:mp": "pnpm --filter @pixbook/miniprogram dev:mp-weixin",
    "build:server": "pnpm --filter @pixbook/server build",
    "build:admin": "pnpm --filter @pixbook/admin build",
    "build:mp": "pnpm --filter @pixbook/miniprogram build:mp-weixin",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,vue,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,css,md,json}\"",
    "db:migrate": "pnpm --filter @pixbook/server db:migrate",
    "db:seed": "pnpm --filter @pixbook/server db:seed",
    "db:studio": "pnpm --filter @pixbook/server db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
