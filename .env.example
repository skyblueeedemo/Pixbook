# ── Database (生产环境务必修改为强密码) ────────────────
# MySQL 8.0 连接字符串
DATABASE_URL="mysql://pixbook:CHANGE_ME@127.0.0.1:3306/pixbook"

# ── Redis ────────────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6379"

# ── JWT (openssl rand -hex 32 生成随机字符串) ──────────
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHAR_STRING"

# ── WeChat Mini Program (从微信公众平台获取) ────────────
WX_APP_ID="wxREPLACE_ME"
WX_APP_SECRET="REPLACE_ME"

# ── Admin ────────────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_ME_TO_STRONG_PASSWORD"

# ── Server ───────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────
# 首次部署:
#   1. 复制此文件为 packages/server/.env
#   2. 修改所有 CHANGE_ME / REPLACE_ME 占位符
#   3. 执行 pnpm db:migrate && pnpm db:seed
#   4. 执行 pnpm build:server && pm2 start ecosystem.config.js
# ─────────────────────────────────────────────────────
