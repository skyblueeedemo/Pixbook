{
  "pages": [
    {
      "path": "pages/home/index",
      "style": {
        "navigationBarTitleText": "修图约-Pixbook"
      }
    },
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "修图约-Pixbook",
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/success/index",
      "style": {
        "navigationBarTitleText": "预约成功"
      }
    },
    {
      "path": "pages/query/index",
      "style": {
        "navigationBarTitleText": "修图约-Pixbook"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "修图约",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F5F5F5"
  },
  "tabBar": {
    "color": "#999",
    "selectedColor": "#409eff",
    "backgroundColor": "#fff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页",
        "iconPath": "static/tab-home.png",
        "selectedIconPath": "static/tab-home-active.png"
      },
      {
        "pagePath": "pages/index/index",
        "text": "预约",
        "iconPath": "static/tab-book.png",
        "selectedIconPath": "static/tab-book-active.png"
      },
      {
        "pagePath": "pages/query/index",
        "text": "查询",
        "iconPath": "static/tab-search.png",
        "selectedIconPath": "static/tab-search-active.png"
      }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "@/components/ui/$1.vue"
    }
  }
}
